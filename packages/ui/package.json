{
  "name": "@repo/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint -c oxlintrc.json src",
    "format": "prettier src --check",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "solid-js": "catalog:"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "lucide-solid": "catalog:"
  },
  "devDependencies": {
    "@repo/oxlint-config": "workspace:*",
    "@repo/ts-config": "workspace:*",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": {
      "source": "./src/styles.css",
      "import": "./src/styles.css"
    },
    "./*": {
      "source": "./src/components/*",
      "import": "./src/components/*"
    }
  }
}
