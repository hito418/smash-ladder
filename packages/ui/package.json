{
  "name": "@repo/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint -c oxlintrc.json src",
    "format": "prettier src --check",
    "build": "tailwindcss -i ./src/styles.css -o ./dist/styles.css",
    "check-types": "tsc --noEmit",
    "dev": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch"
  },
  "peerDependencies": {
    "solid-js": "catalog:"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "lucide-solid": "catalog:",
    "solid-js": "catalog:"
  },
  "devDependencies": {
    "@repo/oxlint-config": "workspace:*",
    "@repo/ts-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/cli": "^4.2.2",
    "oxlint": "catalog:",
    "postcss": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": {
      "source": "./dist/styles.css",
      "import": "./dist/styles.css"
    },
    "./counter": {
      "types": "./src/Counter.tsx",
      "import": "./src/Counter.tsx"
    }
  }
}
